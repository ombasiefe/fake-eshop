generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model products {
  id          Int        @id @default(autoincrement())
  title       String     @unique
  description String     @db.Text
  price       Float      @db.Float
  image       String     @unique
  isActive    Boolean    @default(false)
  categoryId  Int
  category    categories @relation(fields: [categoryId], references: [id])
}

model categories {
  id       Int        @id @default(autoincrement())
  name     String     @unique
  products products[]
}
